// ─── Bookings ───────────────────────────────────────────────────────────────

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Who holds a booking — a registered team, a walk-in individual, or a club.
enum CustomerType {
  TEAM
  INDIVIDUAL
  CLUB
}

/// How the booking was created.
enum BookingSource {
  WALK_IN
  ONLINE
  SUBSCRIPTION
}

/// Venue-side payment state for a booking (simple ledger; distinct from the
/// gateway Payment workflow used for online transactions).
enum BookingPaymentStatus {
  PAID
  PENDING
  PARTIAL
}

/// A reservation of a Court for a given time window.
///
/// Money fields are stored at booking time so historical totals stay correct
/// even if the court's `pricePerHour` changes later. The state machine flows
/// PENDING_PAYMENT -> CONFIRMED -> COMPLETED (or NO_SHOW), with CANCELLED as
/// a terminal sink. Every transition writes a row to `BookingStatusEvent` so
/// admins can audit the timeline.
model Booking {
  id String @id @default(cuid())

  /// The registered player who booked online. Null for venue-created bookings
  /// (walk-ins / phone), which carry denormalised customer fields instead.
  userId  String?
  user    User?   @relation("UserBookings", fields: [userId], references: [id], onDelete: SetNull)
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  courtId String
  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)

  /// Venue-created bookings store the customer inline (loyalty is keyed by phone).
  customerName  String?
  customerPhone String?
  customerType  CustomerType  @default(INDIVIDUAL)
  source        BookingSource @default(WALK_IN)

  /// Staff member who created the booking (venue panel). Null for online bookings.
  createdById String?
  createdBy   User?   @relation("UserBookingsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  startAt         DateTime
  endAt           DateTime
  durationMinutes Int

  /// Snapshot of pricing at booking time — never recomputed.
  pricePerHour   Decimal              @db.Decimal(10, 2)
  subtotal       Decimal              @db.Decimal(10, 2)
  serviceFee     Decimal              @default(0) @db.Decimal(10, 2)
  discountAmount Decimal              @default(0) @db.Decimal(10, 2)
  total          Decimal              @db.Decimal(10, 2)
  /// True when redeemed as a free loyalty game (total = 0).
  freeGame       Boolean              @default(false)
  paymentStatus  BookingPaymentStatus @default(PENDING)
  amountPaid     Decimal              @default(0) @db.Decimal(10, 2)
  paymentMethod  PaymentProvider?

  status             BookingStatus @default(PENDING_PAYMENT)
  cancellationReason String?
  cancelledById      String?
  cancelledBy        User?         @relation("UserCancelledBookings", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancelledAt        DateTime?
  completedAt        DateTime?

  /// Free-text admin note. Surfaced in the admin detail drawer only.
  adminNotes String?

  payment        Payment?
  statusEvents   BookingStatusEvent[]
  refundRequests RefundRequest[]
  disputes       Dispute[]
  /// Add-on services the customer used, captured at completion (reflected in total).
  extras         BookingExtra[]

  /// The offer redeemed on this booking, if any (reflected in discountAmount).
  offerId String?
  offer   Offer?  @relation(fields: [offerId], references: [id], onDelete: SetNull)

  /// The venue customer this booking is for (loyalty is keyed by this id). Null for
  /// online player bookings (which carry `userId`) and legacy rows.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([venueId])
  @@index([courtId])
  @@index([status])
  @@index([startAt])
  @@index([venueId, startAt])
  @@index([customerPhone])
  @@index([offerId])
  @@index([venueId, customerPhone, status])
  @@index([customerId])
  @@index([customerId, status])
  @@map("bookings")
}

/// A venue's customer — a person or a team the front desk books under. One unified
/// record (teams are just customers with a team name). Created/searched by venue
/// staff; loyalty is keyed by this id. Completed games are derived from bookings.
model Customer {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)

  /// The app account, when this customer is a registered player (else null = walk-in).
  /// One customer per app user per venue; a walk-in is "claimed" by setting this on
  /// their first app booking/subscription with the same phone.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Party type. Authoritative for the venue's customer list; bookings snapshot it into
  /// `Booking.customerType`. A walk-in/app player is INDIVIDUAL; a clan/team is TEAM.
  kind CustomerType @default(INDIVIDUAL)

  name  String
  phone String?
  notes String?

  bookings      Booking[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A phone uniquely identifies a customer within a venue (multiple NULLs allowed).
  @@unique([venueId, phone])
  // …and so does the app user (NULLs don't collide in Postgres → walk-ins are fine).
  @@unique([venueId, userId])
  @@index([venueId])
  @@index([userId])
  @@index([venueId, kind])
  @@map("customers")
}

/// Append-only timeline entry for a Booking. Created by the service layer on
/// every state transition so the admin can replay the booking's lifecycle.
model BookingStatusEvent {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fromStatus BookingStatus?
  toStatus   BookingStatus

  actorId String?
  actor   User?   @relation("UserBookingStatusEvents", fields: [actorId], references: [id], onDelete: SetNull)
  note    String?

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_status_events")
}

/// A single add-on service (e.g. "Bib rental") charged on a booking. Captured at
/// completion from the venue's additional services or a one-off custom line item.
model BookingExtra {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  name  String
  price Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@map("booking_extras")
}
