# ──────────────────────────────────────────────────────────
# Arena NP — environment variables (current scope: auth + users)
# Copy to .env and fill in. Validated by src/config/env.validation.ts
# Payment / storage / FCM vars will be added as those modules land.
# ──────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_PORT=4000
APP_NAME=arenanp-backend
APP_URL=http://localhost:4000
APP_TIMEZONE=Asia/Kathmandu
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (Postgres) — Docker compose exposes Postgres on host port 5433
# to avoid clashing with a local Postgres on 5432.
DATABASE_URL=postgresql://arenanp:arenanp@localhost:5433/arenanp?schema=public

# Redis (used for OTP storage + rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT (phone+OTP login issues access tokens)
JWT_ACCESS_SECRET=replace-me-access-secret-min-32-chars-xxxxxxxxxx
JWT_ACCESS_TTL=7d

# OTP
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# SMS provider (stub prints to logs in dev; swap for Sparrow SMS / similar in prod)
SMS_PROVIDER=stub
SMS_API_KEY=
SMS_SENDER_ID=ArenaNP

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# GraphQL — Apollo v5 serves the embedded Sandbox in dev by default
GRAPHQL_INTROSPECTION=true

# Logging
LOG_LEVEL=debug

# Seed super admin (used by prisma/seed.ts)
SEED_SUPER_ADMIN_PHONE=+9779800000000
SEED_SUPER_ADMIN_NAME=Arena NP Admin
