{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ArenaNpS3ObjectRW",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::__BUCKET__/*"
    },
    {
      "Sid": "ArenaNpS3ListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::__BUCKET__"
    }
  ]
}
